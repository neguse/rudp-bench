{
  "transport": "raw_udp",
  "server_command": [
    "build-v2-rawudp/raw_udp_server",
    "--port",
    "42916"
  ],
  "client_command": [
    "build-v2-rawudp/raw_udp_client",
    "--host",
    "127.0.0.1",
    "--port",
    "42916",
    "--conns",
    "{conns}",
    "--proc-index",
    "{proc_index}",
    "--origin-base",
    "{origin_id_start}"
  ],
  "client_procs": 1,
  "total_conns": 3,
  "scenario": {
    "name": "environment-baseline-smoke",
    "kind": "environment_baseline",
    "client_input": {
      "traffic_id": 1,
      "loss_tolerant": {
        "rate_hz": 100,
        "payload_bytes": 64,
        "staleness_p99_ns": 100000000,
        "min_delivery_ratio": 1
      },
      "must_deliver": {
        "rate_hz": 0,
        "payload_bytes": 0
      }
    }
  },
  "warmup": "2s",
  "steady_warmup": true,
  "duration": "2s",
  "drain": "500ms",
  "staleness_period_ns": 10000000,
  "output_dir": "results-v2/local-baseline-rawudp"
}
