{
  "measurement_mode": "screening",
  "regime": "provisional-loss-pipeline-smoke-v1",
  "netem": {
    "server_egress": {
      "delay_ms": 25,
      "loss_pct": 1
    },
    "client_egress": {
      "delay_ms": 25,
      "loss_pct": 1
    }
  },
  "transports": {
    "enet": {
      "server_command": [
        "build-v2-enet/enet_server",
        "--port",
        "42917"
      ],
      "client_command": [
        "build-v2-enet/enet_client",
        "--host",
        "10.200.0.1",
        "--port",
        "42917",
        "--conns",
        "{conns}",
        "--proc-index",
        "{proc_index}",
        "--origin-base",
        "{origin_id_start}"
      ],
      "client_procs": 1
    },
    "websocket": {
      "server_command": [
        "servers/websocket/WebSocketBench.Server/bin/Release/net10.0/WebSocketBench.Server",
        "--port",
        "42933"
      ],
      "client_command": [
        "servers/websocket/WebSocketBench.Client/bin/Release/net10.0/WebSocketBench.Client",
        "--host",
        "10.200.0.1",
        "--port",
        "42933",
        "--conns",
        "{conns}",
        "--proc-index",
        "{proc_index}",
        "--origin-base",
        "{origin_id_start}"
      ],
      "client_procs": 1,
      "sched_is_measurand": true
    }
  },
  "scenarios": [
    {
      "name": "authoritative-state-provisional-loss",
      "kind": "authoritative_state",
      "client_input": {
        "traffic_id": 1,
        "loss_tolerant": {
          "rate_hz": 13,
          "payload_bytes": 64,
          "staleness_p99_ns": 300000000,
          "min_delivery_ratio": 0.95
        },
        "must_deliver": {
          "rate_hz": 10,
          "payload_bytes": 64,
          "deadline_ns": 200000000,
          "min_deadline_hit_ratio": 0.95,
          "min_eventual_delivery_ratio": 1
        }
      },
      "server_state": {
        "traffic_id": 2,
        "loss_tolerant": {
          "rate_hz": 20,
          "payload_bytes": 64,
          "staleness_p99_ns": 300000000,
          "min_delivery_ratio": 0.95
        },
        "must_deliver": {
          "rate_hz": 10,
          "payload_bytes": 64,
          "deadline_ns": 200000000,
          "min_deadline_hit_ratio": 0.95,
          "min_eventual_delivery_ratio": 1
        }
      }
    },
    {
      "name": "room-relay-provisional-loss",
      "kind": "room_relay",
      "room_publish": {
        "traffic_id": 3,
        "loss_tolerant": {
          "rate_hz": 20,
          "payload_bytes": 128,
          "staleness_p99_ns": 300000000,
          "min_delivery_ratio": 0.95
        },
        "must_deliver": {
          "rate_hz": 10,
          "payload_bytes": 64,
          "deadline_ns": 200000000,
          "min_deadline_hit_ratio": 0.95,
          "min_eventual_delivery_ratio": 1
        }
      }
    }
  ],
  "conns": {
    "min": 3,
    "max": 3
  },
  "seed": 20260711,
  "warmup": "25s",
  "duration": "30s",
  "drain": "5s",
  "staleness_period_ns": 10000000,
  "server_cpus": "7,15",
  "client_cpus": "3,4,5,6,11,12,13,14",
  "output_dir": "results-v2/sweep-scenario-loss-provisional"
}
