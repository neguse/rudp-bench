{
 "regime": "wired",
 "netem": {
  "server_egress": {
   "delay_ms": 10,
   "loss_pct": 0.1
  },
  "client_egress": {
   "delay_ms": 10,
   "loss_pct": 0.1
  }
 },
 "workloads": [
  "r10p128",
  "r10p200",
  "r10p1000",
  "r20p128",
