{
  "measurement_mode": "conformance",
  "regime": "local-conformance",
  "transports": {
    "enet": {
      "server_command": ["build-v2-enet/enet_server", "--port", "42917"],
      "client_command": [
        "build-v2-enet/enet_client", "--host", "127.0.0.1", "--port", "42917",
        "--conns", "{conns}", "--proc-index", "{proc_index}", "--origin-base", "{origin_id_start}"
      ],
      "client_procs": 1
    },
    "gns": {
      "server_command": ["build-v2-gns/gns_server", "--port", "42921"],
      "client_command": [
        "build-v2-gns/gns_client", "--host", "127.0.0.1", "--port", "42921",
        "--conns", "{conns}", "--proc-index", "{proc_index}", "--origin-base", "{origin_id_start}"
      ],
      "client_procs": 1
    },
    "litenetlib": {
      "server_command": [
        "servers/litenetlib/LiteNetLibBench.Server/bin/Release/net10.0/LiteNetLibBench.Server",
        "--port", "42941"
      ],
      "client_command": [
        "servers/litenetlib/LiteNetLibBench.Client/bin/Release/net10.0/LiteNetLibBench.Client",
        "--host", "127.0.0.1", "--port", "42941", "--conns", "{conns}",
        "--proc-index", "{proc_index}", "--origin-base", "{origin_id_start}"
      ],
      "client_procs": 1
    },
    "magiconion": {
      "server_command": [
        "servers/magiconion/MagicOnionBench.Server/bin/Release/net10.0/MagicOnionBench.Server",
        "--port", "42931"
      ],
      "client_command": [
        "servers/magiconion/MagicOnionBench.Client/bin/Release/net10.0/MagicOnionBench.Client",
        "--host", "127.0.0.1", "--port", "42931", "--conns", "{conns}",
        "--proc-index", "{proc_index}", "--origin-base", "{origin_id_start}"
      ],
      "client_procs": 1,
      "sched_is_measurand": true
    },
    "msquic": {
      "server_command": ["build-v2-msquic/msquic_server", "--port", "42919"],
      "client_command": [
        "build-v2-msquic/msquic_client", "--host", "127.0.0.1", "--port", "42919",
        "--conns", "{conns}", "--proc-index", "{proc_index}", "--origin-base", "{origin_id_start}"
      ],
      "client_procs": 1
    },
    "websocket": {
      "server_command": [
        "servers/websocket/WebSocketBench.Server/bin/Release/net10.0/WebSocketBench.Server",
        "--port", "42933"
      ],
      "client_command": [
        "servers/websocket/WebSocketBench.Client/bin/Release/net10.0/WebSocketBench.Client",
        "--host", "127.0.0.1", "--port", "42933", "--conns", "{conns}",
        "--proc-index", "{proc_index}", "--origin-base", "{origin_id_start}"
      ],
      "client_procs": 1,
      "sched_is_measurand": true
    }
  },
  "scenarios": [
    {
      "name": "authoritative-state-conformance",
      "kind": "authoritative_state",
      "client_input": {
        "traffic_id": 1,
        "loss_tolerant": {
          "rate_hz": 13, "payload_bytes": 64,
          "staleness_p99_ns": 200000000, "min_delivery_ratio": 1
        },
        "must_deliver": {
          "rate_hz": 1, "payload_bytes": 64, "deadline_ns": 200000000,
          "min_deadline_hit_ratio": 1, "min_eventual_delivery_ratio": 1
        }
      },
      "server_state": {
        "traffic_id": 2,
        "loss_tolerant": {
          "rate_hz": 20, "payload_bytes": 64,
          "staleness_p99_ns": 200000000, "min_delivery_ratio": 1
        },
        "must_deliver": {
          "rate_hz": 1, "payload_bytes": 64, "deadline_ns": 200000000,
          "min_deadline_hit_ratio": 1, "min_eventual_delivery_ratio": 1
        }
      }
    },
    {
      "name": "room-relay-conformance",
      "kind": "room_relay",
      "room_publish": {
        "traffic_id": 3,
        "loss_tolerant": {
          "rate_hz": 20, "payload_bytes": 128,
          "staleness_p99_ns": 200000000, "min_delivery_ratio": 1
        },
        "must_deliver": {
          "rate_hz": 1, "payload_bytes": 64, "deadline_ns": 200000000,
          "min_deadline_hit_ratio": 1, "min_eventual_delivery_ratio": 1
        }
      }
    }
  ],
  "conns": {"min": 3, "max": 3},
  "seed": 20260710,
  "warmup": "2s",
  "duration": "2s",
  "drain": "500ms",
  "staleness_period_ns": 10000000,
  "output_dir": "results-v2/scenario-conformance-local"
}
