{
  "transport": "enet",
  "server_command": ["build-v2-enet/enet_server", "--port", "42917"],
  "client_command": ["build-v2-enet/enet_client",
    "--host", "127.0.0.1", "--port", "42917",
    "--conns", "{conns}", "--proc-index", "{proc_index}",
    "--origin-base", "{origin_id_start}",
    "--rate-lt", "50", "--rate-md", "50", "--payload", "64",
    "--deadline-ns", "150000000", "--staleness-period-ns", "10000000"],
  "client_procs": 2,
  "total_conns": 4,
  "warmup": "1s",
  "duration": "3s",
  "drain": "1s",
  "deadline_ns": 150000000,
  "staleness_period_ns": 10000000,
  "output_dir": "results-v2/local-enet"
}
