{
 "regime": "wired",
 "netem": {
  "server_egress": {
   "delay_ms": 10,
   "loss_pct": 0.1
  },
  "client_egress": {
   "delay_ms": 10,
   "loss_pct": 0.1
  }
 },
 "workloads": [
  "r10p128"
 ],
 "conns": {
  "min": 16,
  "max": 512
 },
 "seed": 1,
 "warmup": "1s",
 "drain": "1s",
 "deadline_ns": 150000000,
 "staleness_period_ns": 10000000,
 "output_dir": "results-v2/sweep-wired-ab-gcserver",
 "transports": {
  "magiconion": {
   "server_command": [
    "servers/magiconion/MagicOnionBench.Server/bin/Release/net10.0/MagicOnionBench.Server",
    "--port",
    "42931"
   ],
   "client_command": {
    "path": "servers/magiconion/MagicOnionBench.Client/bin/Release/net10.0/MagicOnionBench.Client",
    "args": [
     "--host",
     "10.200.0.1",
     "--port",
     "42931",
     "--conns",
     "{conns}",
     "--proc-index",
     "{proc_index}",
     "--origin-base",
     "{origin_id_start}",
     "--deadline-ns",
     "150000000",
     "--staleness-period-ns",
     "10000000"
    ],
    "env": [
     "DOTNET_gcServer=1"
    ]
   },
   "client_procs": 4
  },
  "websocket": {
   "server_command": [
    "servers/websocket/WebSocketBench.Server/bin/Release/net10.0/WebSocketBench.Server",
    "--port",
    "42933"
   ],
   "client_command": {
    "path": "servers/websocket/WebSocketBench.Client/bin/Release/net10.0/WebSocketBench.Client",
    "args": [
     "--host",
     "10.200.0.1",
     "--port",
     "42933",
     "--conns",
     "{conns}",
     "--proc-index",
     "{proc_index}",
     "--origin-base",
     "{origin_id_start}",
     "--deadline-ns",
     "150000000",
     "--staleness-period-ns",
     "10000000"
    ],
    "env": [
     "DOTNET_gcServer=1"
    ]
   },
   "client_procs": 4
  }
 },
 "duration": "10s"
}
