      "must_deliver": {
        "rate_hz": 0,
        "payload_bytes": 0
      }
    }
  },
  "netem": {
    "server_egress": {
      "delay_ms": 25,
      "loss_pct": 1
    },
    "client_egress": {
      "delay_ms": 25,
      "loss_pct": 1
    }
  },
  "warmup": "25s",
  "duration": "30s",
  "drain": "5s",
  "staleness_period_ns": 10000000,
  "server_cpus": "7,15",
  "client_cpus": "3,4,5,6,11,12,13,14",
  "output_dir": "results-v2/environment-baseline-loss-provisional"
