{
  "transport": "websocket",
  "workload": "echo",
  "server_command": ["servers/websocket/WebSocketBench.Server/bin/Release/net10.0/WebSocketBench.Server", "--port", "42932"],
  "client_command": ["servers/websocket/WebSocketBench.Client/bin/Release/net10.0/WebSocketBench.Client",
    "--host", "127.0.0.1", "--port", "42932",
    "--conns", "{conns}", "--proc-index", "{proc_index}",
    "--origin-base", "{origin_id_start}",
    "--deadline-ns", "150000000", "--staleness-period-ns", "10000000"],
  "client_procs": 2,
  "total_conns": 4,
  "warmup": "1s",
  "duration": "3s",
  "drain": "1s",
  "deadline_ns": 150000000,
  "staleness_period_ns": 10000000,
  "output_dir": "results-v2/local-websocket"
}
