{
  "version": 1,
  "probe": {
    "version": 2,
    "family_alpha": 0.01,
    "family_alpha_scope": "per_transport_four_loss_cases",
    "loss_percent": 1,
    "payload_bytes": 1000,
    "link_mtu_bytes": 1500,
    "slots_per_run": 1000,
    "total_connections": 1,
    "require_exact_submission": true,
    "valid_acquisitions_per_case": 1,
    "max_attempts_per_case": 2,
    "rate_hz": 50,
    "warmup_ns": 25000000000,
    "duration_ns": 20000000000,
    "drain_ns": 5000000000
  },
  "server_cpus": "2-3",
  "client_cpus": "8-63",
  "output_dir": "results-v2/ref1-probe-enet",
  "transports": {
    "raw_udp": {
      "server_command": [
        "build-v2-rawudp/raw_udp_server",
        "--port",
        "42916"
      ],
      "client_command": [
        "build-v2-rawudp/raw_udp_client",
        "--host",
        "10.200.0.1",
        "--port",
        "42916",
        "--conns",
        "{conns}",
        "--proc-index",
        "{proc_index}",
        "--origin-base",
        "{origin_id_start}"
      ],
      "client_procs": 1,
      "diagnostic": true
    },
    "enet": {
      "server_command": [
        "build-v2-enet/enet_server",
        "--port",
        "42917"
      ],
      "client_command": [
        "build-v2-enet/enet_client",
        "--host",
        "10.200.0.1",
        "--port",
        "42917",
        "--conns",
        "{conns}",
        "--proc-index",
        "{proc_index}",
        "--origin-base",
        "{origin_id_start}"
      ],
      "client_procs": 1
    }
  }
}
