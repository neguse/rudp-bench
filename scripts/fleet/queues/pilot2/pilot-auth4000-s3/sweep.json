{
  "regime": "ref-wan-pilot",
  "netem": {
    "link_mtu_bytes": 1500,
    "disable_offloads": true,
    "server_egress": {
      "delay_ms": 25,
      "loss_pct": 1
    },
    "client_egress": {
      "delay_ms": 25,
      "loss_pct": 1
    }
  },
  "scenarios": [
    {
      "name": "ref-auth-state4000-wan-v1",
      "kind": "authoritative_state",
      "client_input": {
        "traffic_id": 1,
        "loss_tolerant": {
          "rate_hz": 30,
          "payload_bytes": 64,
          "staleness_p99_ns": 300000000,
          "min_delivery_ratio": 0.95
        },
        "must_deliver": {
          "rate_hz": 10,
          "payload_bytes": 64,
          "deadline_ns": 200000000,
          "min_deadline_hit_ratio": 0.95,
          "min_eventual_delivery_ratio": 1
        }
      },
      "server_state": {
        "traffic_id": 2,
        "loss_tolerant": {
          "rate_hz": 20,
          "payload_bytes": 4000,
          "staleness_p99_ns": 300000000,
          "min_delivery_ratio": 0.95
        },
        "must_deliver": {
          "rate_hz": 10,
          "payload_bytes": 64,
          "deadline_ns": 200000000,
          "min_deadline_hit_ratio": 0.95,
          "min_eventual_delivery_ratio": 1
        }
      }
    }
  ],
  "conns": {
    "min": 4,
    "max": 512
  },
  "seed": 3,
  "warmup": "25s",
  "steady_warmup": true,
  "duration": "60s",
  "drain": "5s",
  "staleness_period_ns": 10000000,
  "output_dir": "__JOB__/out/cell",
  "transports": {
    "enet": {
      "server_command": [
        "build-v2-enet/enet_server",
        "--port",
        "42917"
      ],
      "client_command": [
        "build-v2-enet/enet_client",
        "--host",
        "10.200.0.1",
        "--port",
        "42917",
        "--conns",
        "{conns}",
        "--proc-index",
        "{proc_index}",
        "--origin-base",
        "{origin_id_start}"
      ],
      "client_procs": 8,
      "steady_min_warmup": "15s"
    }
  }
}
