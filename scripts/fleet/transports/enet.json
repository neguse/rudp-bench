{
  "name": "enet",
  "spec": {
    "server_command": ["build-v2-enet/enet_server", "--port", "42917"],
    "client_command": [
      "build-v2-enet/enet_client", "--host", "10.200.0.1", "--port", "42917",
      "--conns", "{conns}", "--proc-index", "{proc_index}",
      "--origin-base", "{origin_id_start}"
    ],
    "client_procs": 8,
    "steady_min_warmup": "15s"
  }
}
